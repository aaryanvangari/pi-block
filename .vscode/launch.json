    "version": "0.2.0",
    "configurations": [
        {
            "name": "pi_block",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=ENV=dev",
                "--dart-define=SERVER_URL=${env:PIHOLE_SERVER_URL}",
                "--dart-define=API_TOKEN=${env:PIHOLE_API_TOKEN}"
            ]
        },
        {
            "name": "pi_block (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "pi_block (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}