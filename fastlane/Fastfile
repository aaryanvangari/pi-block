default_platform(:android)
opt_out_usage

platform :android do

  desc "Upload new build to Internal testing"
  lane :internal do
    version_code = ENV["VERSION_CODE"]
    upload_to_play_store(
      track: "internal",
      aab: ENV["AAB_PATH"] || "build/app/outputs/bundle/release/app-release.aab",
      version_code: version_code,
      
      # Enable changelog upload
      skip_upload_metadata: false,
      
      skip_upload_images: false,
      skip_upload_screenshots: false,

      # Sync images from the metadata directory to the Play Store
      # Change it to true only if you want to sync, otherwise it will delete existing ones from the Play Store
      sync_image_upload: true
    )
  end

  desc "Promote build from Internal → Alpha"
  lane :alpha do
    version_code = ENV["VERSION_CODE"]
    upload_to_play_store(
      track: "internal",
      track_promote_to: "alpha",
      version_code: version_code,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

end

platform :ios do
  desc "Upload to TestFlight"

  lane :beta do
    upload_to_testflight(
      ipa: ENV["IPA_PATH"],
      api_key_path: "./fastlane/app_store_connect_api_key.json",
      # submit_for_review: true,
      # automatic_release: false
    )
  end
end